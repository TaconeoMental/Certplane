{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certplane.whisper.cl/schemas/broker.schema.json",
  "title": "Certplane Broker Configuration",
  "description": "Configuration file for certplane-broker",
  "type": "object",
  "required": ["server", "policy", "identity_ca", "public_ca"],
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "required": ["address", "tls"],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "description": "Address and port to listen on.",
          "examples": ["0.0.0.0:8443"]
        },
        "tls": {
          "type": "object",
          "required": ["cert", "key", "client_ca"],
          "additionalProperties": false,
          "properties": {
            "cert": {
              "type": "string",
              "description": "Path to the broker TLS server certificate (PEM) issued by the internal CA."
            },
            "key": {
              "type": "string",
              "description": "Path to the broker TLS server private key (PEM)."
            },
            "client_ca": {
              "type": "string",
              "description": "Path to the internal root CA certificate (PEM). Used to validate agent identity certificates."
            },
            "min_version": {
              "type": "string",
              "description": "Minimum TLS version accepted.",
              "enum": ["1.2", "1.3"],
              "default": "1.2"
            }
          }
        }
      }
    },

    "policy": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the policy.yaml file."
        },
        "watch": {
          "type": "boolean",
          "description": "If true, the broker reloads policy.yaml automatically when the file changes.",
          "default": false
        }
      }
    },

    "identity_ca": {
      "type": "object",
      "required": ["provider"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Identity CA provider to use.",
          "enum": ["step-ca"]
        },
        "step_ca": {
          "type": "object",
          "description": "Configuration for the step-ca provider. Required when provider is step-ca.",
          "required": ["url", "fingerprint"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "description": "URL of the step-ca API.",
              "examples": ["https://ca.int.whisper.cl:9000"]
            },
            "fingerprint": {
              "type": "string",
              "description": "SHA256 fingerprint of the step-ca root CA certificate."
            },
            "root_ca": {
              "type": "string",
              "description": "Path to the step-ca root CA certificate (PEM). Optional if fingerprint is provided."
            },
            "timeout": {
              "type": "string",
              "description": "Timeout for step-ca API calls. Go duration string.",
              "examples": ["10s", "30s"],
              "default": "10s"
            }
          }
        }
      }
    },

    "public_ca": {
      "type": "object",
      "required": ["provider"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Public CA provider to use.",
          "enum": ["letsencrypt"]
        },
        "letsencrypt": {
          "type": "object",
          "description": "Configuration for the Let's Encrypt provider. Required when provider is letsencrypt.",
          "required": ["email", "directory", "challenge"],
          "additionalProperties": false,
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "description": "Email address for the ACME account."
            },
            "directory": {
              "type": "string",
              "description": "ACME directory to use.",
              "enum": ["production", "staging"],
              "default": "staging"
            },
            "challenge": {
              "type": "string",
              "description": "ACME challenge type.",
              "enum": ["dns-01", "http-01"]
            },
            "dns": {
              "type": "object",
              "description": "DNS challenge configuration. Required when challenge is dns-01.",
              "required": ["provider", "credentials"],
              "additionalProperties": false,
              "properties": {
                "provider": {
                  "type": "string",
                  "description": "DNS provider for the dns-01 challenge.",
                  "enum": ["cloudflare"]
                },
                "propagation_timeout": {
                  "type": "string",
                  "description": "Time to wait for DNS propagation before asking Let's Encrypt to verify.",
                  "examples": ["60s", "120s"],
                  "default": "120s"
                },
                "polling_interval": {
                  "type": "string",
                  "description": "Interval between DNS propagation checks.",
                  "examples": ["10s"],
                  "default": "10s"
                },
                "credentials": {
                  "$ref": "#/$defs/secret_ref"
                }
              }
            },
            "http": {
              "type": "object",
              "description": "HTTP challenge configuration. Required when challenge is http-01.",
              "additionalProperties": false,
              "properties": {
                "port": {
                  "type": "integer",
                  "description": "Port to listen on for the http-01 challenge.",
                  "default": 80
                }
              }
            },
            "data_dir": {
              "type": "string",
              "description": "Directory where lego stores ACME account data and issued certificates.",
              "default": "/var/lib/certplane/lego"
            },
            "renew_before": {
              "type": "string",
              "description": "If the broker has a cached certificate with less than this time remaining, it renews instead of returning the cached bundle.",
              "examples": ["720h"],
              "default": "720h"
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Secrets provider to use.",
          "enum": ["file", "env", "vault"],
          "default": "file"
        },
        "vault": {
          "type": "object",
          "description": "Vault provider configuration. Required when provider is vault.",
          "required": ["address", "token_file"],
          "additionalProperties": false,
          "properties": {
            "address": {
              "type": "string",
              "description": "URL of the Vault server.",
              "examples": ["https://vault.int.whisper.cl:8200"]
            },
            "token_file": {
              "type": "string",
              "description": "Path to a file containing the Vault token."
            }
          }
        }
      }
    },

    "state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the SQLite database file used to store issuance state.",
          "default": "/var/lib/certplane/broker.db"
        }
      }
    },

    "logging": {
      "$ref": "#/$defs/logging"
    }
  },

  "$defs": {
    "secret_ref": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "description": "Reference to a secret in the configured secrets provider.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name or path of the secret. Interpreted by the active secrets provider: a file path for file provider, an env var name for env provider, a Vault path for vault provider."
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "format": {
          "type": "string",
          "enum": ["json", "text"],
          "description": "Log output format.",
          "default": "json"
        },
        "file": {
          "type": "string",
          "description": "If set, logs are written to this file in addition to stdout."
        }
      }
    }
  }
}

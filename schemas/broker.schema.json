{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certplane.whisper.cl/schemas/broker.schema.json",
  "title": "Certplane Broker Configuration",
  "type": "object",
  "required": ["server", "policy", "issuer"],
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "required": ["tls", "mtls"],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "description": "Address and port to listen on.",
          "default": ":8443",
          "examples": ["0.0.0.0:8443"]
        },
        "tls": {
          "type": "object",
          "required": ["cert", "key"],
          "additionalProperties": false,
          "properties": {
            "cert": {
              "type": "string",
              "description": "Path to the broker TLS server certificate (PEM)."
            },
            "key": {
              "type": "string",
              "description": "Path to the broker TLS server private key (PEM)."
            },
            "min_version": {
              "type": "string",
              "enum": ["1.2", "1.3"],
              "description": "Minimum TLS version accepted.",
              "default": "1.2"
            }
          }
        },
        "mtls": {
          "type": "object",
          "required": ["agent_ca_bundle"],
          "additionalProperties": false,
          "properties": {
            "agent_ca_bundle": {
              "type": "string",
              "description": "Path to the CA bundle used to verify agent identity certificates (PEM)."
            }
          }
        },
        "read_header_timeout": {
          "type": "string",
          "description": "Maximum time to read request headers.",
          "default": "5s"
        },
        "read_timeout": {
          "type": "string",
          "description": "Maximum time to read an entire request.",
          "default": "10s"
        },
        "write_timeout": {
          "type": "string",
          "description": "Maximum time to write a response.",
          "default": "60s"
        },
        "idle_timeout": {
          "type": "string",
          "description": "Maximum time to keep an idle connection open.",
          "default": "120s"
        }
      }
    },

    "policy": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the policy YAML file."
        },
        "watch": {
          "type": "boolean",
          "description": "Reload the policy file automatically when it changes on disk.",
          "default": false
        }
      }
    },

    "issuer": {
      "type": "object",
      "required": ["provider"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["acme"],
          "description": "Certificate issuer provider.",
          "default": "acme"
        },
        "acme": {
          "type": "object",
          "description": "ACME provider configuration. Required when provider is acme.",
          "required": ["directory_url", "account_email", "account_key", "dns_provider"],
          "additionalProperties": false,
          "properties": {
            "directory_url": {
              "type": "string",
              "description": "ACME directory URL.",
              "examples": [
                "https://acme-v02.api.letsencrypt.org/directory",
                "https://acme-staging-v02.api.letsencrypt.org/directory"
              ]
            },
            "account_email": {
              "type": "string",
              "description": "Email address for the ACME account."
            },
            "account_key": {
              "type": "string",
              "description": "Path to the ACME account private key (PEM)."
            },
            "dns_provider": {
              "type": "string",
              "enum": ["cloudflare", "httpreq"],
              "description": "DNS provider for dns-01 challenges."
            },
            "preferred_chain": {
              "type": "string",
              "description": "Preferred certificate chain name. Defaults to the CA's chain if unset."
            }
          }
        }
      }
    },

    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["env", "file", "vault", "openbao"],
          "description": "Secrets provider used to resolve credentials referenced in profiles.",
          "default": "env"
        },
        "vault": {
          "type": "object",
          "description": "Vault/OpenBao provider configuration. Required when provider is vault or openbao.",
          "additionalProperties": false,
          "properties": {
            "address": {
              "type": "string",
              "description": "URL of the Vault or OpenBao server.",
              "examples": ["https://vault.int.whisper.cl:8200"]
            },
            "token": {
              "type": "string",
              "description": "Vault token. Use token_file in production."
            },
            "token_file": {
              "type": "string",
              "description": "Path to a file containing the Vault token."
            },
            "mount_path": {
              "type": "string",
              "description": "KV secrets engine mount path.",
              "default": "secret"
            },
            "kv_version": {
              "type": "integer",
              "enum": [1, 2],
              "description": "KV secrets engine version.",
              "default": 2
            },
            "key": {
              "type": "string",
              "description": "Key within the secret to read.",
              "default": "value"
            },
            "timeout": {
              "type": "string",
              "description": "Timeout for Vault API calls.",
              "default": "10s"
            },
            "namespace": {
              "type": "string",
              "description": "Vault Enterprise namespace."
            }
          }
        }
      }
    },

    "store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "driver": {
          "type": "string",
          "enum": ["sqlite", "file"],
          "description": "Storage backend driver.",
          "default": "sqlite"
        },
        "path": {
          "type": "string",
          "description": "Path to the store file (SQLite DB or JSON cache file).",
          "default": "/var/lib/certplane/broker.db"
        }
      }
    },

    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Set to false to disable audit logging.",
          "default": true
        },
        "failure_mode": {
          "type": "string",
          "enum": ["fail_open", "fail_closed"],
          "description": "fail_closed rejects the request on audit failure, fail_open allows it.",
          "default": "fail_open"
        },
        "mirror_to_log": {
          "type": "boolean",
          "description": "Also emit audit events as structured log lines.",
          "default": false
        }
      }
    },

    "rate_limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "per_identity_per_hour": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum certificate requests per identity per hour. 0 disables the limit.",
          "default": 50
        },
        "per_identity_profile_per_hour": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum certificate requests per identity+profile pair per hour. 0 disables the limit.",
          "default": 20
        }
      }
    },

    "logging": {
      "$ref": "#/$defs/logging"
    }
  },

  "$defs": {
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "format": {
          "type": "string",
          "enum": ["text", "json"],
          "default": "json"
        },
        "destination": {
          "type": "string",
          "enum": ["stdout", "stderr"],
          "default": "stdout"
        }
      }
    }
  }
}
